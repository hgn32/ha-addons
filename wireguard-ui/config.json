{
  "name": "WireGuard UI",
  "description": "WireGuard VPN サーバー + Web 管理画面 (ngoduykhanh/wireguard-ui)",
  "version": "0.1",
  "slug": "wireguard_ui",
  "url": "https://github.com/ngoduykhanh/wireguard-ui",
  "init": false,
  "arch": [
    "amd64",
    "aarch64"
  ],
  "startup": "services",
  "boot": "auto",
  "host_network": false,
  "privileged": [
    "NET_ADMIN"
  ],
  "ports": {
    "5000/tcp": 5000,
    "51820/udp": 51820
  },
  "ports_description": {
    "5000/tcp": "Web UI (HTTP)",
    "51820/udp": "WireGuard VPN"
  },
  "webui": "http://[HOST]:[PORT:5000]",
  "options": {
    "username": "wireguardadmin",
    "password": "adminwireguard",
    "endpoint_address": "",
    "server_interface_addresses": [
      "10.252.1.0/24"
    ],
    "server_listen_port": 51820,
    "default_client_dns": "1.1.1.1",
    "default_client_allowed_ips": "0.0.0.0/0",
    "mtu": 1420,
    "persistent_keepalive": 15,
    "manage_wireguard": true,
    "post_up_script": "iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE; iptables -A FORWARD -i %i -j ACCEPT; iptables -A FORWARD -o %i -j ACCEPT",
    "post_down_script": "iptables -t nat -D POSTROUTING -o eth0 -j MASQUERADE; iptables -D FORWARD -i %i -j ACCEPT; iptables -D FORWARD -o %i -j ACCEPT",
    "log_level": "INFO"
  },
  "schema": {
    "username": "str",
    "password": "password",
    "endpoint_address": "str?",
    "server_interface_addresses": [
      "match(^([0-9]{1,3}\\.){3}[0-9]{1,3}/[1-3]?[0-9]$)"
    ],
    "server_listen_port": "port",
    "default_client_dns": "str?",
    "default_client_allowed_ips": "str?",
    "default_client_extra_allowed_ips": "str?",
    "mtu": "int(1280,1500)?",
    "persistent_keepalive": "int(0,)?",
    "manage_wireguard": "bool",
    "post_up_script": "str?",
    "post_down_script": "str?",
    "log_level": "list(DEBUG|INFO|WARN|ERROR|OFF)?",
    "subnet_ranges": [
      "match(^[^:]+: ?(,?([0-9]{1,3}\\.){3}[0-9]{1,3}/[1-3]?[0-9])+$)"
    ],
    "email_from_address": "str?",
    "email_from_name": "str?",
    "sendgrid_api_key": "password?",
    "smtp_hostname": "str?",
    "smtp_port": "int(0,65535)?",
    "smtp_username": "str?",
    "smtp_password": "password?",
    "smtp_auth_type": "list(PLAIN|LOGIN|NONE)?",
    "smtp_encryption": "list(NONE|SSL|SSLTLS|TLS|STARTTLS)?",
    "smtp_helo": "str?",
    "telegram_token": "password?",
    "telegram_allow_conf_request": "bool?",
    "telegram_flood_wait": "int(0,)?"
  },
  "_image": "ghcr.io/hgn32/wireguard-ui"
}
