{
  "name": "WireGuard UI",
  "description": "WireGuard VPN サーバー + Web 管理画面 (ngoduykhanh/wireguard-ui)",
  "version": "0.6",
  "slug": "wireguard_ui",
  "url": "https://github.com/ngoduykhanh/wireguard-ui",
  "init": false,
  "arch": [
    "amd64",
    "aarch64"
  ],
  "startup": "services",
  "boot": "auto",
  "host_network": false,
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:vpn",
  "panel_title": "WireGuard VPN",
  "privileged": [
    "NET_ADMIN",
    "SYS_ADMIN"
  ],
  "ports": {
    "51820/udp": 51820
  },
  "map": [
    {
      "type": "homeassistant_config",
      "read_only": false,
      "path": "/config"
    }
  ],
  "options": {
    "single_user_mode": true,
    "default_interface_addresses": [
      "192.168.101.0/24"
    ],
    "subnet_ranges": [
      "mobile: 192.168.101.0/26",
      "esphome: 192.168.101.64/26"
    ],
    "dmz_subnet": [],
    "dmz_subnet_allow": [
      "default_route_ip|53/udp"
    ]
  },
  "schema": {
    "single_user_mode": "bool",
    "default_interface_addresses": [
      "match(^([0-9]{1,3}\\.){3}[0-9]{1,3}/[1-3]?[0-9]$)?"
    ],
    "subnet_ranges": [
      "match(^[^:]+: ?(,?([0-9]{1,3}\\.){3}[0-9]{1,3}/[1-3]?[0-9])+$)?"
    ],
    "dmz_subnet": [
      "match(^([0-9]{1,3}\\.){3}[0-9]{1,3}/[1-3]?[0-9]$)?"
    ],
    "dmz_subnet_allow": [
      "match(^((((default_route_ip|([0-9]{1,3}\\.){3}[0-9]{1,3}(/[1-3]?[0-9])?)\\|?){1,2}([0-9,:]+/(tcp|udp|icmp|any))?))$)?"
    ],
    "default_client_dns": "str?",
    "default_client_endpoint": "str?",
    "log_level": "list(trace|debug|info|notice|warning|error|fatal)?"
  },
  "_image": "ghcr.io/hgn32/wireguard-ui"
}
