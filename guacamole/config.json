{
  "name": "Guacamole",
  "description": "軽量版 Apache Guacamole。guacd + Tomcat + 外部 PostgreSQL",
  "version": "1.6.0-22",
  "slug": "guacamole",
  "url": "https://guacamole.apache.org/",
  "init": false,
  "arch": [
    "amd64",
    "aarch64"
  ],
  "startup": "application",
  "boot": "auto",
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:remote-desktop",
  "panel_title": "Guacamole",
  "host_network": false,
  "map": [
    {
      "type": "addon_config",
      "read_only": false,
      "path": "/config"
    }
  ],
  "backup": "hot",
  "backup_pre": "/usr/local/bin/guac-backup.sh",
  "options": {
    "pg_host": "db21ed7f-postgres-latest",
    "pg_port": 5432,
    "pg_user": "postgres",
    "pg_password": "",
    "pg_database": "guacamole_db",
    "backup_enabled": true,
    "vacuum_logs_on_backup": false,
    "extensions": [],
    "ingress_auto_login": true,
    "ingress_auto_login_user": "guacadmin",
    "max_memory_mb": 1024
  },
  "schema": {
    "pg_host": "str",
    "pg_port": "int?",
    "pg_user": "str?",
    "pg_password": "password?",
    "pg_database": "str?",
    "backup_enabled": "bool",
    "vacuum_logs_on_backup": "bool",
    "extensions": [
      "list(auth-totp|auth-duo|auth-header|auth-json|auth-ldap|auth-quickconnect|auth-ban|display-statistics|history-recording-storage|auth-sso-openid|auth-sso-saml|auth-sso-cas|auth-jdbc-mysql|auth-jdbc-sqlserver|vault-ksm)"
    ],
    "ingress_auto_login": "bool",
    "ingress_auto_login_user": "str",
    "max_memory_mb": "int(128,8192)?"
  },
  "image": "ghcr.io/hgn32/guacamole"
}
