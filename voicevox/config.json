{
  "name": "VOICEVOX Engine",
  "description": "VOICEVOX Engine for Home Assistant",
  "version": "0.12",
  "slug": "voiceboxengine",
  "init": false,
  "arch": [
    "amd64",
    "aarch64"
  ],
  "startup": "services",
  "host_network": true,
  "watchdog": "http://[HOST]:[PORT:50021]/version",
  "options": {
    "max_memory_mb": 0,
    "load_all_models": true,
    "preload_speaker_ids": []
  },
  "schema": {
    "max_memory_mb": "int(0,16384)?",
    "load_all_models": "bool?",
    "preload_speaker_ids": ["str"]
  },
  "image": "ghcr.io/hgn32/voicevox"
}
