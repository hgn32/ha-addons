{
  "name": "Suwayomi Server",
  "description": "Self-hosted manga server compatible with Mihon (.tachibk バックアップビューア内蔵)",
  "version": "0.17",
  "slug": "suwayomi_server",
  "init": false,
  "arch": [
    "amd64",
    "aarch64"
  ],
  "startup": "services",
  "map_root": true,
  "ports": {
    "4567/tcp": 4567
  },
  "ports_description": {
    "4567/tcp": "Suwayomi Server web UI"
  },
  "boot": "auto",
  "tmpfs": false,
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:book-open-variant",
  "panel_title": "Suwayomi Summary",
  "map": [
    {
      "type": "addon_config",
      "read_only": false,
      "path": "/config"
    },
    "media:rw"
  ],
  "options": {
    "suwayomi_url": "http://localhost:4567",
    "suwayomi_username": "",
    "suwayomi_password": "",
    "max_memory_mb": 2048
  },
  "schema": {
    "suwayomi_url": "url",
    "suwayomi_username": "str?",
    "suwayomi_password": "password?",
    "max_memory_mb": "int(256,8192)?"
  },
  "image": "ghcr.io/hgn32/suwayomi-server"
}