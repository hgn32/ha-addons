{
  "name": "Suwayomi Server",
  "description": "Self-hosted manga server compatible with Mihon",
  "version": "0.9",
  "slug": "suwayomi_server",
  "init": false,
  "arch": [
    "amd64",
    "aarch64"
  ],
  "startup": "services",
  "map_root": true,
  "ports": {
    "4567/tcp": 4567
  },
  "ports_description": {
    "4567/tcp": "http interface"
  },
  "boot": "auto",
  "tmpfs": false,
  "map": [
    {
      "type": "addon_config",
      "read_only": false,
      "path": "/config"
    },
    "media:rw"
  ],
  "image": "ghcr.io/hgn32/suwayomi-server"
}