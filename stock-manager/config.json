{
  "name": "Stock Manager",
  "description": "在庫管理アプリ。品目・カテゴリ・置き場・購入先の管理、在庫操作・履歴記録、Amazon購入履歴の自動取込に対応。",
  "version": "0.10.2",
  "slug": "stock_manager",
  "image": "ghcr.io/hgn32/stock-manager",
  "init": false,
  "arch": [
    "amd64",
    "aarch64"
  ],
  "startup": "services",
  "ingress": true,
  "ingress_port": 8099,
  "ingress_stream": false,
  "homeassistant_api": true,
  "panel_icon": "mdi:package-variant-closed",
  "panel_title": "Stock Manager",
  "map": [
    {
      "type": "addon_config",
      "read_only": false,
      "path": "/config"
    }
  ],
  "options": {
    "amazon_cron": "0 18 * * *",
    "notify_enabled": true,
    "force_schema_push": false
  },
  "schema": {
    "amazon_cron": "str",
    "notify_enabled": "bool?",
    "force_schema_push": "bool?"
  }
}
