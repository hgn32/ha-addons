generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id         String    @id @default(uuid())
  name       String
  note       String    @default("")
  icon       String    @default("")
  sort_order Int       @default(0)
  created_at DateTime  @default(now())
  products   Product[]
}

model Location {
  id         String    @id @default(uuid())
  name       String
  note       String    @default("")
  icon       String    @default("")
  sort_order Int       @default(0)
  created_at DateTime  @default(now())
  products   Product[]
}

model Supplier {
  id           String        @id @default(uuid())
  name         String
  url          String        @default("")
  note         String        @default("")
  sort_order   Int           @default(0)
  created_at   DateTime      @default(now())
  transactions Transaction[]
}

model Product {
  id          String        @id @default(uuid())
  name        String
  volume      String        @default("")
  piece_count Int           @default(1)
  maker       String        @default("")
  jan_code    String        @default("")
  amazon_asin String        @default("")
  amazon_url  String        @default("")
  category_id String?
  location_id String?
  note        String        @default("")
  photo       String        @default("")
  quantity    Int           @default(0)
  // 在庫警告のしきい値。在庫がこの数になると「警告」、下回ると「エラー」表示。
  warn_quantity Int         @default(1)
  sort_order  Int           @default(0)
  created_at  DateTime      @default(now())
  category     Category?     @relation(fields: [category_id], references: [id])
  location     Location?     @relation(fields: [location_id], references: [id])
  asins        ProductAsin[]
  barcodes     ProductBarcode[]
  transactions Transaction[]
}

// One product can be associated with multiple ASINs (e.g. same item re-listed or capacity variants)
// piece_count: このASINで1個購入したときに加算する実在庫数（容量違い・まとめ買い対応）。
model ProductAsin {
  id          String   @id @default(uuid())
  product_id  String
  asin        String   @unique
  piece_count Int      @default(1)
  created_at  DateTime @default(now())
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
}

// One product can have multiple scanned barcodes (JAN/EAN/UPC). The primary
// jan_code field stays for display/CSV; extra barcodes linked via the
// 棚卸 screen are stored here so scans resolve to the right product.
model ProductBarcode {
  id          String   @id @default(uuid())
  product_id  String
  code        String   @unique
  piece_count Int      @default(1)
  created_at  DateTime @default(now())
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
}

model Transaction {
  id          String   @id @default(uuid())
  type        String
  product_id  String
  quantity    Int
  unit_price  Float    @default(0)
  supplier_id String?
  note        String   @default("")
  date        DateTime @default(now())
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  supplier    Supplier? @relation(fields: [supplier_id], references: [id])

  @@index([product_id])
}

// Key/value store for crawler state (e.g. amazon_last_sync, amazon_cookie).
model Setting {
  key   String @id
  value String @default("")
}

// Items crawled from Amazon order history waiting to be triaged.
// status: pending (要手動) / managed (在庫管理する) / skipped (今回スキップ)
model AmazonQueue {
  id           String   @id @default(uuid())
  order_id     String   @default("")
  asin         String   @default("")
  jan_code     String   @default("")
  product_name String
  maker        String   @default("")
  product_url  String   @default("")
  image_url    String   @default("")
  purchased_at DateTime
  quantity     Int      @default(1)
  unit_price   Float    @default(0)
  status        String   @default("pending")
  enrich_failed Boolean  @default(false)
  created_at    DateTime @default(now())

  @@index([status])
}

