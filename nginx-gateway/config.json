{
  "name": "Nginx Gateway",
  "description": "Nginx Gateway",
  "version": "0.10.4",
  "slug": "nginx_gateway",
  "url": "https://yhc.jp",
  "init": false,
  "homeassistant_api": false,
  "hassio_api": false,
  "arch": [
    "amd64"
  ],
  "startup": "services",
  "boot": "auto",
  "host_network": false,
  "ports": {
    "443/tcp": 443,
    "8883/tcp": 8883,
    "51820/udp": 51820
  },
  "ports_description": {
    "443/tcp": "Public HTTPS",
    "8883/tcp": "Public MQTTs",
    "51820/udp": "Public WireGuard"
  },
  "map": [
    "share:rw",
    "ssl:ro"
  ],
  "options": {
    "geoip_account_id": "",
    "geoip_license_key": "",
    "geoip_update_schedule": "0 18 * * *",
    "geoip_reload_nginx": true
  },
  "schema": {
    "geoip_account_id": "str?",
    "geoip_license_key": "password?",
    "geoip_update_schedule": "str?",
    "geoip_reload_nginx": "bool?"
  },
  "image": "ghcr.io/hgn32/nginx-gateway"
}
