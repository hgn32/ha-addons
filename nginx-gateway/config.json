{
  "name": "Nginx Gateway",
  "description": "Nginx Gateway",
  "version": "0.1.0",
  "slug": "nginx_gateway",
  "url": "https://yhc.jp",
  "init": false,
  "homeassistant_api": false,
  "hassio_api": false,
  "arch": [
    "amd64",
    "aarch64"
  ],
  "startup": "services",
  "boot": "auto",
  "host_network": false,
  "build": {
    "dockerfile": "Dockerfile"
  },
  "ports": {
    "443/tcp": 443,
    "8883/tcp": 8883,
    "51820/udp": 51820
  },
  "ports_description": {
    "443/tcp": "Public HTTPS",
    "8883/tcp": "Public MQTTs",
    "51820/udp": "Public WireGuard"
  },
    "map": ["share:rw","ssl:ro"]
}
