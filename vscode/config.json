{
  "name": "Studio Code Server",
  "description": "ブラウザからアクセスできる Visual Studio Code (VSCode) 環境を Home Assistant フロントエンドに統合します。",
  "version": "6.0.1",
  "slug": "vscode",
  "url": "https://github.com/hassio-addons/addon-vscode",
  "init": false,
  "arch": [
    "aarch64",
    "amd64"
  ],
  "startup": "services",
  "boot": "auto",
  "ingress": true,
  "ingress_port": 1337,
  "ingress_stream": true,
  "panel_icon": "mdi:microsoft-visual-studio-code",
  "panel_title": "VS Code",
  "hassio_api": true,
  "hassio_role": "manager",
  "homeassistant_api": true,
  "map": [
    {
      "type": "addons",
      "read_only": false
    },
    {
      "type": "all_addon_configs",
      "read_only": false
    },
    {
      "type": "backup",
      "read_only": false
    },
    {
      "type": "homeassistant_config",
      "read_only": false,
      "path": "/config"
    },
    {
      "type": "media",
      "read_only": false
    },
    {
      "type": "share",
      "read_only": false
    },
    {
      "type": "ssl",
      "read_only": false
    }
  ],
  "backup_pre": "/usr/local/bin/vscode-backup-pre.sh",
  "options": {
    "max_memory_mb": 2048,
    "packages": [],
    "init_commands": []
  },
  "schema": {
    "log_level": "list(trace|debug|info|notice|warning|error|fatal)?",
    "config_path": "str?",
    "max_memory_mb": "int?",
    "packages": [
      "str"
    ],
    "init_commands": [
      "str"
    ]
  },
  "_image": "ghcr.io/hgn32/vscode"
}
