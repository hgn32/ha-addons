{
  "files.watcherExclude": {
    ".nfs**": true,
    ".Trash-0/**": true,
    "**/__pycache__/**": true,
    "**/*.pyc": true,
    "**/*.pyo": true,
    "**/.venv/**": true,
    "**/.mypy_cache/**": true,
    "**/.pytest_cache/**": true,
    "**/._*": true,
    "**/.cache/**": true,
    "**/.cloud": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.HA_VERSION": true,
    "**/.storage/**": true,
    "**/*.db-shm": true,
    "**/*.db-wal": true,
    "**/*.db": true,
    "**/*.log": true,
    "**/*.gz": true,
    "**/*.tar": true,
    "**/backups/**": true,
    "**/deps/**": true,
    "**/media/**": true,
    "**/node_modules": true,
    "**/OZW_Log.txt": true,
    "**/pyozw.sqlite": true,
    "**/tts/**": true,
    "**/www/**": true,
    "**/tmp/**": true,
    "**/*.bak": true,
    "**/*.orig": true,
    "**/.idea/**": true
  },
  "search.exclude": {
    ".Trash-0/**": true,
    "**/__pycache__/**": true,
    "**/*.pyc": true,
    "**/*.pyo": true,
    "**/.venv/**": true,
    "**/._*": true,
    "**/.cache/**": true,
    "**/.cloud": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.git": true,
    "**/.HA_VERSION": true,
    "**/.storage/**": true,
    "**/*.db-shm": true,
    "**/*.db-wal": true,
    "**/*.db": true,
    "**/*.log": true,
    "**/*.gz": true,
    "**/*.tar": true,
    "**/backups/**": true,
    "**/deps/**": true,
    "**/media/**": true,
    "**/node_modules": true,
    "**/OZW_Log.txt": true,
    "**/pyozw.sqlite": true,
    "**/tts/**": true,
    "**/www/**": true,
    "**/tmp/**": true,
    "**/*.bak": true,
    "**/*.orig": true,
    "**/.idea/**": true
  },
  "files.exclude": {
    ".Trash-0/**": true,
    "**/__pycache__": true,
    "**/.cache/**": true,
    "**/.cloud": true,
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.HA_VERSION": true,
    "**/.storage/**": true,
    "**/*.db-shm": true,
    "**/*.db-wal": true,
    "**/*.db": true,
    "**/deps/**": true,
    "**/node_modules": true,
    "**/tts/**": true
  },
  "editor.renderWhitespace": "boundary",
  "editor.rulers": [80, 100, 120],
  "telemetry.enableTelemetry": false,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.shell.linux": "/usr/bin/zsh",
  "update.mode": "none",
  "workbench.iconTheme": "material-icon-theme"
}
